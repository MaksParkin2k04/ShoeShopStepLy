@page
@using ShoeShop.Models
@model ShoeShop.Pages.Admin.CategoriesModel
@{
    ViewData["Title"] = "Управление категориями";
}

<div class="admin-page">
    <div class="admin-header">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h1 class="admin-title">
                    <i class="fas fa-tags me-3"></i>
                    Управление категориями
                </h1>
                <p class="admin-subtitle">Создание и редактирование категорий товаров</p>
            </div>
            <a asp-page="/Admin/Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Админ панель
            </a>
        </div>
    </div>

    @* Add Category Form *@
    <div class="add-category-section mb-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Добавить новую категорию</h5>
            </div>
            <div class="card-body">
                <form asp-page="/Admin/Categories" asp-page-handler="Add" method="post" class="row g-3">
                    <div class="col-md-8">
                        <input type="text" name="categoryName" class="form-control" placeholder="Название категории" required>
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-plus me-2"></i>
                            Добавить
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @* Categories List *@
    <div class="categories-list">
        @if (Model.Categories == null || !Model.Categories.Any()) {
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fas fa-tags fa-4x"></i>
                </div>
                <h3 class="empty-title">Категории не найдены</h3>
                <p class="empty-text">Добавьте первую категорию товаров</p>
            </div>
        } else {
            <div class="row g-3">
                @foreach (Category category in Model.Categories) {
                    <div class="col-md-6 col-lg-4">
                        <div class="category-card">
                            <div class="category-info">
                                <h5 class="category-name">@category.Name</h5>
                            </div>
                            <div class="category-actions">
                                <form asp-page="/Admin/Categories" asp-page-handler="Delete" method="post" class="d-inline" id="delete-form-@category.Id">
                                    <input type="hidden" name="categoryId" value="@category.Id" />
                                    <button type="button" class="btn btn-sm btn-outline-danger delete-category-btn" 
                                            data-category-id="@category.Id"
                                            data-category-name="@category.Name">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @* Модальное окно подтверждения удаления *@
    <div class="modal fade" id="deleteCategoryModal" tabindex="-1" aria-labelledby="deleteCategoryModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteCategoryModalLabel">Подтверждение удаления категории</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="noProductsMessage" style="display: none;">
                        <p>Вы уверены, что хотите удалить категорию <strong id="categoryName"></strong>?</p>
                    </div>
                    <div id="hasProductsMessage" style="display: none;">
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            <strong>Внимание!</strong> В категории <strong id="categoryNameWithProducts"></strong> находится <span id="productCount" class="badge bg-danger"></span> товар(ов).
                        </div>
                        <p>Вы не можете удалить категорию, к которой привязаны товары.</p>
                        <p>Выберите один из вариантов:</p>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" name="deleteOption" id="optionCancel" value="cancel" checked>
                            <label class="form-check-label" for="optionCancel">
                                Отменить удаление
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="deleteOption" id="optionDeleteAll" value="deleteAll">
                            <label class="form-check-label" for="optionDeleteAll">
                                Удалить категорию вместе со всеми товарами (<span id="productCount2"></span> шт.)
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Удалить</button>
                </div>
            </div>
        </div>
    </div>

    @* JavaScript для обработки удаления *@
    @section Scripts {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                let currentCategoryId = null;
                let currentCategoryName = null;
                let currentProductCount = 0;
                
                // Обработчики для кнопок удаления
                document.querySelectorAll('.delete-category-btn').forEach(btn => {
                    btn.addEventListener('click', function() {
                        currentCategoryId = this.getAttribute('data-category-id');
                        currentCategoryName = this.getAttribute('data-category-name');
                        
                        // Проверяем наличие товаров через AJAX
                        checkCategoryHasProducts(currentCategoryId);
                    });
                });
                
                // Кнопка подтверждения удаления
                document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
                    if (!currentCategoryId) return;
                    
                    const deleteOption = document.querySelector('input[name="deleteOption"]:checked').value;
                    const form = document.getElementById('delete-form-' + currentCategoryId);
                    
                    if (deleteOption === 'deleteAll') {
                        // Добавляем скрытое поле для forceDelete
                        const forceDeleteInput = document.createElement('input');
                        forceDeleteInput.type = 'hidden';
                        forceDeleteInput.name = 'forceDelete';
                        forceDeleteInput.value = 'true';
                        form.appendChild(forceDeleteInput);
                    }
                    
                    form.submit();
                });
                
                // Функция проверки наличия товаров
                function checkCategoryHasProducts(categoryId) {
                    fetch('/Admin/Categories?handler=CheckProducts&categoryId=' + categoryId)
                        .then(response => response.json())
                        .then(data => {
                            currentProductCount = data.productCount;
                            showDeleteModal(data.hasProducts);
                        })
                        .catch(error => {
                            console.error('Error:', error);
                            // Если AJAX не работает, показываем стандартное подтверждение
                            showDeleteModal(false);
                        });
                }
                
                // Функция показа модального окна
                function showDeleteModal(hasProducts) {
                    const modal = new bootstrap.Modal(document.getElementById('deleteCategoryModal'));
                    
                    if (hasProducts) {
                        // Показываем сообщение с товарами
                        document.getElementById('noProductsMessage').style.display = 'none';
                        document.getElementById('hasProductsMessage').style.display = 'block';
                        document.getElementById('categoryNameWithProducts').textContent = currentCategoryName;
                        document.getElementById('productCount').textContent = currentProductCount;
                        document.getElementById('productCount2').textContent = currentProductCount;
                        document.getElementById('confirmDeleteBtn').disabled = true;
                        
                        // Обработчик изменения выбора опции
                        document.querySelectorAll('input[name="deleteOption"]').forEach(radio => {
                            radio.addEventListener('change', function() {
                                document.getElementById('confirmDeleteBtn').disabled = this.value === 'cancel';
                            });
                        });
                    } else {
                        // Показываем простое сообщение
                        document.getElementById('noProductsMessage').style.display = 'block';
                        document.getElementById('hasProductsMessage').style.display = 'none';
                        document.getElementById('categoryName').textContent = currentCategoryName;
                        document.getElementById('confirmDeleteBtn').disabled = false;
                    }
                    
                    modal.show();
                }
            });
        </script>
    }
</div>