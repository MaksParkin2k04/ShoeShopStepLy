@page "/OrderTracking/Track/{orderId}"
@model ShoeShop.Pages.OrderTracking.TrackModel
@{
    ViewData["Title"] = "Отслеживание заказа";
}

<div class="container mt-4">
    @if (Model.Order != null)
    {
        <div class="row">
            <div class="col-md-8 mx-auto">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">📦 Заказ №@Model.Order.Id</h4>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h6>Статус заказа:</h6>
                                <span class="badge bg-@(Model.Order.Status == ShoeShop.Models.OrderStatus.Paid ? "success" : "warning") fs-6">
                                    @switch (Model.Order.Status)
                                    {
                                        case ShoeShop.Models.OrderStatus.Created: <text>Заказ создан</text> break;
                                        case ShoeShop.Models.OrderStatus.Paid: <text>Оплачен</text> break;
                                        case ShoeShop.Models.OrderStatus.Processing: <text>В обработке</text> break;
                                        case ShoeShop.Models.OrderStatus.AwaitingShipment: <text>Ожидает отправления</text> break;
                                        case ShoeShop.Models.OrderStatus.Shipped: <text>Отправлен</text> break;
                                        case ShoeShop.Models.OrderStatus.InTransit: <text>В пути</text> break;
                                        case ShoeShop.Models.OrderStatus.Arrived: <text>Прибыл</text> break;
                                        case ShoeShop.Models.OrderStatus.ReadyForPickup: <text>Готов к выдаче</text> break;
                                        case ShoeShop.Models.OrderStatus.Completed: <text>Выполнен</text> break;
                                        case ShoeShop.Models.OrderStatus.Returned: <text>Возвращен</text> break;
                                        case ShoeShop.Models.OrderStatus.Canceled: <text>Отменен</text> break;
                                    }
                                </span>
                            </div>
                            <div class="col-md-6">
                                <h6>Дата создания:</h6>
                                <p>@Model.Order.CreatedDate.ToString("dd.MM.yyyy HH:mm")</p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h6>Получатель:</h6>
                                <p class="mb-1"><strong>@Model.Order.Recipient.Name</strong></p>
                                <p class="mb-1">📞 @Model.Order.Recipient.Phone</p>
                                <p class="mb-0">📍 @Model.Order.Recipient.City, @Model.Order.Recipient.Street @Model.Order.Recipient.House</p>
                            </div>
                            <div class="col-md-6">
                                <h6>Доставка:</h6>
                                @switch (Model.Order.DeliveryType)
                                {
                                    case ShoeShop.Models.DeliveryType.Courier:
                                        <p class="mb-0">🚚 Курьерская доставка</p>
                                        break;
                                    case ShoeShop.Models.DeliveryType.Pickup:
                                        <p class="mb-0">🏢 Самовывоз из магазина</p>
                                        break;
                                    case ShoeShop.Models.DeliveryType.RussianPost:
                                        <p class="mb-0">📮 Почта России</p>
                                        break;
                                    case ShoeShop.Models.DeliveryType.CDEK:
                                        <p class="mb-0">📦 СДЭК</p>
                                        break;
                                    case ShoeShop.Models.DeliveryType.Boxberry:
                                        <p class="mb-0">📦 Boxberry</p>
                                        break;
                                }
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h6>Оплата:</h6>
                                @if (Model.Order.PaymentType == ShoeShop.Models.PaymentType.Online)
                                {
                                    <p class="mb-1">💳 Онлайн оплата</p>
                                    @if (Model.Order.PaymentDate.HasValue)
                                    {
                                        <p class="text-success mb-0">✅ Оплачено @Model.Order.PaymentDate.Value.ToString("dd.MM.yyyy HH:mm")</p>
                                    }
                                    else
                                    {
                                        <p class="text-warning mb-0">⏳ Ожидает оплаты</p>
                                    }
                                }
                                else
                                {
                                    <p class="mb-0">💰 Оплата при получении</p>
                                }
                            </div>
                        </div>

                        <h6>Товары в заказе:</h6>
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Товар</th>
                                        <th>Размер</th>
                                        <th class="text-end">Цена</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Order.OrderDetails)
                                    {
                                        <tr>
                                            <td>@item.Name</td>
                                            <td>@item.Size</td>
                                            <td class="text-end">@item.Price₽</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr class="fw-bold">
                                        <td colspan="2">Итого:</td>
                                        <td class="text-end">@Model.Order.OrderDetails.Sum(x => x.Price)₽</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Order.Coment))
                        {
                            <div class="mt-3">
                                <h6>Комментарий:</h6>
                                <p class="text-muted">@Model.Order.Coment</p>
                            </div>
                        }
                        
                        @if (User.IsInRole("Admin"))
                        {
                            <div class="mt-4 pt-3 border-top">
                                <h6>Администратор:</h6>
                                <form asp-page="/OrderTracking/Track" asp-page-handler="UpdateStatus" method="post" class="d-inline">
                                    <input type="hidden" name="orderId" value="@Model.Order.Id" />
                                    <select name="status" class="form-select form-select-sm d-inline-block" style="width: auto;" onchange="this.form.submit()">
                                        @foreach (var status in Enum.GetValues<ShoeShop.Models.OrderStatus>())
                                        {
                                            <option value="@status" selected="@(status == Model.Order.Status)">
                                                @switch (status)
                                                {
                                                    case ShoeShop.Models.OrderStatus.Created: <text>Заказ создан</text> break;
                                                    case ShoeShop.Models.OrderStatus.Paid: <text>Оплачен</text> break;
                                                    case ShoeShop.Models.OrderStatus.Processing: <text>В обработке</text> break;
                                                    case ShoeShop.Models.OrderStatus.AwaitingShipment: <text>Ожидает отправления</text> break;
                                                    case ShoeShop.Models.OrderStatus.Shipped: <text>Отправлен</text> break;
                                                    case ShoeShop.Models.OrderStatus.InTransit: <text>В пути</text> break;
                                                    case ShoeShop.Models.OrderStatus.Arrived: <text>Прибыл</text> break;
                                                    case ShoeShop.Models.OrderStatus.ReadyForPickup: <text>Готов к выдаче</text> break;
                                                    case ShoeShop.Models.OrderStatus.Completed: <text>Выполнен</text> break;
                                                    case ShoeShop.Models.OrderStatus.Returned: <text>Возвращен</text> break;
                                                    case ShoeShop.Models.OrderStatus.Canceled: <text>Отменен</text> break;
                                                }
                                            </option>
                                        }
                                    </select>
                                </form>
                                <a asp-page="/Admin/OrderDetail" asp-route-id="@Model.Order.Id" class="btn btn-primary btn-sm">
                                    <i class="fas fa-edit me-1"></i>Редактировать заказ
                                </a>
                                <a asp-page="/OrderLabel" asp-route-orderId="@Model.Order.Id" class="btn btn-success btn-sm" target="_blank">
                                    <i class="fas fa-print me-1"></i>Печать этикетки
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            <h4>Заказ не найден</h4>
            <p>Проверьте правильность ссылки или обратитесь в службу поддержки.</p>
        </div>
    }
</div>